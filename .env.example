# ============================================================
#  CrowdWisdomTrading Ads AI Agent - Environment Variables
#  Copy this file to .env and fill in your real values.
# ============================================================

# --- LLM Provider (OpenRouter) ---
OPENROUTER_API_KEY=YOUR_OPENROUTER_API_KEY_HERE
OPENROUTER_MODEL=meta-llama/llama-3.3-8b-instruct:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# --- Apify (Meta Ads Scraping) ---
APIFY_API_TOKEN=YOUR_APIFY_API_TOKEN_HERE

# --- ElevenLabs (Voice Generation) ---
ELEVENLABS_API_KEY=YOUR_ELEVENLABS_API_KEY_HERE
ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMaL

# --- Google Drive (Brand Data Source) ---
# Either a public shareable file ID or a folder ID
GDRIVE_FILE_ID=YOUR_GOOGLE_DRIVE_FILE_ID_HERE
# Path to your GDrive service account JSON (leave blank to use gdown with public link)
GDRIVE_SERVICE_ACCOUNT_JSON=

# --- Target Configuration ---
TARGET_NICHE=trading education stock market signals
TARGET_BRAND=CrowdWisdomTrading
TARGET_WEBSITE=https://www.crowdwisdomtrading.com
AD_DURATION_SECONDS=60

# --- Remotion / Node ---
REMOTION_OUTPUT_DIR=outputs/videos
NODE_ENV=development
